# ===========================================
# Centro360 Financeiro — Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# --- Banco de Dados ---
# Deixe vazio para usar SQLite local (desenvolvimento)
# Preencha com a URL do PostgreSQL para produção (Render/Railway/Supabase)
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE

# --- Segurança JWT ---
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# No Render: use "Generate Value" para criar automaticamente
JWT_SECRET=troque-por-uma-chave-secreta-forte-minimo-32-caracteres

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- CORS (opcional) ---
# Se quiser restringir o acesso a um domínio específico
# CORS_ORIGIN=https://centro360.onrender.com
